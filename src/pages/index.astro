---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import CategoryNav from '../components/CategoryNav.astro';
import SearchBar from '../components/SearchBar.astro';
import PhraseCard from '../components/PhraseCard.astro';
import SurvivalMode from '../components/SurvivalMode.astro';
import EmptyState from '../components/EmptyState.astro';
import CultureTip from '../components/CultureTip.astro';
import '../styles/global.css';

import phrases from '../data/phrases.json';

const cultureTips: Record<string, string> = {
  greetings: "A small bow goes a long way in Japan. People really appreciate even basic politeness from visitors.",
  apologies: "'Sumimasen' is your Swiss army knife — it works as 'excuse me', 'sorry', and even 'thank you' depending on context.",
  restaurants: "You usually pay at the register near the exit, not at your table. Tipping is not expected and can cause confusion.",
  shopping: "Convenience stores (konbini) are open 24/7 and have great food, ATMs, free Wi-Fi, and even parcel delivery.",
  transport: "Get a Suica or Pasmo IC card — it works on all trains, buses, vending machines, and most convenience stores.",
  drinking: "Many bars charge a cover fee (otoshi) with a snack. At sake bars, try a 'nomikurabe' tasting set — and pour for others before yourself, it's polite!",
  hotel: "Shoes are removed at the entrance in traditional ryokan. Most hotels expect check-in after 3 PM and checkout by 10–11 AM.",
  emergency: "Police: 110 / Ambulance & Fire: 119. Police boxes (koban) are everywhere and officers are very helpful to tourists.",
};

const categoryMeta: Record<string, { label: string; emoji: string }> = {
  greetings: { label: 'Greetings & Basic Politeness', emoji: '👋' },
  apologies: { label: 'Apologies & Help', emoji: '🙏' },
  restaurants: { label: 'Restaurants & Cafes', emoji: '🍜' },
  shopping: { label: 'Convenience Store & Shopping', emoji: '🛍️' },
  transport: { label: 'Train, Taxi & Directions', emoji: '🚃' },
  drinking: { label: 'Bars & Drinks', emoji: '🍺' },
  hotel: { label: 'Hotel & Accommodation', emoji: '🏨' },
  emergency: { label: 'Emergency & Health', emoji: '🚨' },
  numbers: { label: 'Numbers, Time & Useful Words', emoji: '🔢' },
};

const categoryOrder = ['greetings', 'apologies', 'restaurants', 'shopping', 'transport', 'drinking', 'hotel', 'emergency', 'numbers'];
const survivalPhrases = phrases.filter((p) => p.survival);
const grouped = categoryOrder.map((cat) => ({
  id: cat,
  ...categoryMeta[cat],
  phrases: phrases.filter((p) => p.category === cat),
}));
---

<Layout title="Japan Phrasebook 🇯🇵 — Travel Phrases for Tourists">
  <Hero />

  <div class="sticky-header">
    <CategoryNav />
    <SearchBar />
  </div>

  <main class="container">
    <SurvivalMode phrases={survivalPhrases} />

    {grouped.map((group) => (
      <section class="category-section" id={group.id} data-category-section={group.id}>
        <h2 class="category-section__title">
          <span class="category-section__emoji" aria-hidden="true">{group.emoji}</span>
          {group.label}
        </h2>
        {cultureTips[group.id] && <CultureTip tip={cultureTips[group.id]} />}
        <div class="phrase-cards">
          {group.phrases.map((p) => (
            <div id={`card-${p.id}`}>
              <PhraseCard
                id={p.id}
                english={p.english}
                japanese={p.japanese}
                romaji={p.romaji}
                note={p.note || undefined}
              />
            </div>
          ))}
        </div>
      </section>
    ))}

    <EmptyState />
  </main>

  <footer class="footer">
    <p>Made with ♡ for travelers in Japan</p>
    <p>Phrases use polite, tourist-friendly Japanese</p>
  </footer>

  <button class="back-to-top" id="back-to-top" aria-label="Back to top" type="button">↑</button>

  <!-- Show-to-people modal -->
  <div class="modal-overlay" id="phrase-modal" aria-hidden="true" role="dialog" aria-label="Show phrase">
    <div class="modal">
      <div class="modal__top-bar">
        <button class="modal__close" id="modal-close" aria-label="Close" type="button">✕</button>
        <div class="modal__size-controls">
          <button class="modal__size-btn" data-size="sm" aria-label="Small text" type="button">A</button>
          <button class="modal__size-btn active" data-size="md" aria-label="Medium text" type="button">A</button>
          <button class="modal__size-btn" data-size="lg" aria-label="Large text" type="button">A+</button>
          <button class="modal__size-btn" data-size="xl" aria-label="Extra large text" type="button">A++</button>
        </div>
      </div>
      <p class="modal__hint">Show this to the person you're speaking with</p>
      <p class="modal__english" id="modal-english"></p>
      <p class="modal__japanese jp-text size-md" id="modal-japanese"></p>
      <p class="modal__romaji" id="modal-romaji"></p>
      <p class="modal__note" id="modal-note"></p>
    </div>
  </div>

  <script>
    const STORAGE_KEY = 'jap-favorites';
    const THEME_KEY = 'jap-theme';
    const SIZE_KEY = 'jap-modal-size';

    // DOM references
    const searchInput = document.getElementById('phrase-search') as HTMLInputElement;
    const clearBtn = document.getElementById('search-clear')!;
    const favToggle = document.getElementById('fav-toggle')!;
    const emptyState = document.getElementById('empty-state')!;
    const backToTop = document.getElementById('back-to-top')!;
    const darkToggle = document.getElementById('dark-toggle')!;
    const allCards = document.querySelectorAll<HTMLElement>('.phrase-card');
    const allSections = document.querySelectorAll<HTMLElement>('.category-section');
    const allTabs = document.querySelectorAll<HTMLElement>('.category-nav__tab');
    const survival = document.querySelector<HTMLElement>('.survival');

    // Haptic feedback for native-like feel
    function haptic(ms = 10) {
      try { navigator.vibrate?.(ms); } catch {}
    }

    // State
    let favorites: Set<string> = new Set(loadFavorites());
    let showFavOnly = false;

    // --- Dark Mode ---
    function initTheme() {
      const saved = localStorage.getItem(THEME_KEY);
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const isDark = saved ? saved === 'dark' : prefersDark;
      applyTheme(isDark);
    }

    function applyTheme(isDark: boolean) {
      document.documentElement.classList.toggle('dark', isDark);
      darkToggle.textContent = isDark ? '☀️' : '🌙';
      darkToggle.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
    }

    darkToggle.addEventListener('click', () => {
      haptic();
      const isDark = !document.documentElement.classList.contains('dark');
      applyTheme(isDark);
      localStorage.setItem(THEME_KEY, isDark ? 'dark' : 'light');
    });

    initTheme();

    // --- Favorites persistence ---
    function loadFavorites(): string[] {
      try {
        return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
      } catch {
        return [];
      }
    }

    function saveFavorites() {
      localStorage.setItem(STORAGE_KEY, JSON.stringify([...favorites]));
    }

    function renderFavorites() {
      document.querySelectorAll<HTMLButtonElement>('.phrase-card__fav').forEach((btn) => {
        const id = btn.dataset.favId!;
        const isFav = favorites.has(id);
        btn.textContent = isFav ? '♥' : '♡';
        btn.setAttribute('aria-label', isFav ? 'Remove from favorites' : 'Add to favorites');
        btn.style.color = isFav ? 'var(--sakura-dark)' : '';
      });
    }

    // --- Search & filter ---
    let debounceTimer: ReturnType<typeof setTimeout>;

    function filterCards() {
      const query = searchInput.value.trim().toLowerCase();
      let visibleCount = 0;

      allCards.forEach((card) => {
        const en = card.dataset.english || '';
        const rom = card.dataset.romaji || '';
        const jp = card.dataset.japanese || '';
        const id = card.dataset.phraseId || '';

        const matchesSearch = !query || en.includes(query) || rom.includes(query) || jp.includes(query);
        const matchesFav = !showFavOnly || favorites.has(id);
        const visible = matchesSearch && matchesFav;

        card.classList.toggle('hidden', !visible);
        if (visible) visibleCount++;
      });

      allSections.forEach((section) => {
        const visibleCards = section.querySelectorAll('.phrase-card:not(.hidden)');
        section.style.display = visibleCards.length === 0 ? 'none' : '';
      });

      if (survival) {
        survival.style.display = (query || showFavOnly) ? 'none' : '';
      }

      emptyState.classList.toggle('visible', visibleCount === 0);
      clearBtn.classList.toggle('visible', query.length > 0);
    }

    searchInput.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(filterCards, 150);
    });

    clearBtn.addEventListener('click', () => {
      haptic();
      searchInput.value = '';
      filterCards();
      searchInput.focus();
    });

    // --- Favorites toggle ---
    favToggle.addEventListener('click', () => {
      haptic();
      showFavOnly = !showFavOnly;
      favToggle.classList.toggle('active', showFavOnly);
      favToggle.textContent = showFavOnly ? '♥' : '♡';
      favToggle.setAttribute('aria-pressed', String(showFavOnly));
      filterCards();
    });

    // --- Heart & copy buttons (event delegation) ---
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;

      if (target.classList.contains('phrase-card__fav')) {
        haptic();
        const id = target.dataset.favId!;
        if (favorites.has(id)) {
          favorites.delete(id);
        } else {
          favorites.add(id);
        }
        saveFavorites();
        renderFavorites();
        if (showFavOnly) filterCards();
      }

      if (target.closest('.phrase-card__copy')) {
        haptic(15);
        const btn = target.closest('.phrase-card__copy') as HTMLButtonElement;
        const text = btn.dataset.copy || '';
        navigator.clipboard.writeText(text).then(() => {
          const originalText = btn.innerHTML;
          btn.classList.add('copied');
          btn.innerHTML = '<span aria-hidden="true">✓</span> Copied!';
          setTimeout(() => {
            btn.classList.remove('copied');
            btn.innerHTML = originalText;
          }, 1500);
        }).catch(() => {});
      }
    });

    // --- Phrase modal ---
    const modal = document.getElementById('phrase-modal')!;
    const modalClose = document.getElementById('modal-close')!;
    const modalEnglish = document.getElementById('modal-english')!;
    const modalJapanese = document.getElementById('modal-japanese')!;
    const modalRomaji = document.getElementById('modal-romaji')!;
    const modalNote = document.getElementById('modal-note')!;
    const sizeBtns = document.querySelectorAll<HTMLButtonElement>('.modal__size-btn');

    let currentSize = localStorage.getItem(SIZE_KEY) || 'md';

    function setModalSize(size: string) {
      currentSize = size;
      modalJapanese.className = 'modal__japanese jp-text size-' + size;
      sizeBtns.forEach((btn) => {
        btn.classList.toggle('active', btn.dataset.size === size);
      });
      localStorage.setItem(SIZE_KEY, size);
    }

    sizeBtns.forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        setModalSize(btn.dataset.size!);
      });
    });

    function openModal(card: HTMLElement) {
      haptic(15);
      const en = card.querySelector('.phrase-card__english')?.textContent || '';
      const jp = card.querySelector('.phrase-card__japanese')?.textContent || '';
      const rom = card.querySelector('.phrase-card__romaji')?.textContent || '';
      const note = card.querySelector('.phrase-card__note')?.textContent || '';

      modalEnglish.textContent = en;
      modalJapanese.textContent = jp;
      modalRomaji.textContent = rom;

      if (note) {
        modalNote.textContent = note;
        modalNote.classList.add('visible');
      } else {
        modalNote.textContent = '';
        modalNote.classList.remove('visible');
      }

      setModalSize(currentSize);
      modal.classList.add('open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      modalClose.focus();
    }

    function closeModal() {
      modal.classList.remove('open');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    modalClose.addEventListener('click', closeModal);

    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
    });

    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('.phrase-card__fav') || target.closest('.phrase-card__copy')) return;
      const card = target.closest('.phrase-card') as HTMLElement | null;
      if (card) openModal(card);
    });

    // --- Category scroll tracking ---
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const catId = (entry.target as HTMLElement).dataset.categorySection;
            allTabs.forEach((tab) => {
              tab.classList.toggle('active', tab.dataset.category === catId);
            });
          }
        });
      },
      { rootMargin: '-120px 0px -60% 0px', threshold: 0 }
    );

    allSections.forEach((section) => observer.observe(section));

    // --- Smooth scroll for tabs ---
    allTabs.forEach((tab) => {
      tab.addEventListener('click', (e) => {
        haptic();
        e.preventDefault();
        const targetId = tab.dataset.category!;
        const section = document.getElementById(targetId);
        if (section) {
          section.scrollIntoView({ behavior: 'smooth' });
        }
        if (searchInput.value) {
          searchInput.value = '';
          filterCards();
        }
        if (showFavOnly) {
          showFavOnly = false;
          favToggle.classList.remove('active');
          favToggle.textContent = '♡';
          favToggle.setAttribute('aria-pressed', 'false');
          filterCards();
        }
      });
    });

    // --- Back to top ---
    window.addEventListener('scroll', () => {
      backToTop.classList.toggle('visible', window.scrollY > 400);
    }, { passive: true });

    backToTop.addEventListener('click', () => {
      haptic();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    // --- PWA Install Prompt ---
    const installBanner = document.getElementById('install-banner')!;
    const installBtn = document.getElementById('install-btn')!;
    const installDismiss = document.getElementById('install-dismiss')!;
    let deferredPrompt: any = null;

    window.addEventListener('beforeinstallprompt', (e) => {
      e.preventDefault();
      deferredPrompt = e;
      const dismissed = sessionStorage.getItem('jap-install-dismissed');
      if (!dismissed) {
        installBanner.classList.add('visible');
        installBanner.setAttribute('aria-hidden', 'false');
      }
    });

    installBtn.addEventListener('click', async () => {
      if (!deferredPrompt) return;
      deferredPrompt.prompt();
      const { outcome } = await deferredPrompt.userChoice;
      deferredPrompt = null;
      installBanner.classList.remove('visible');
      installBanner.setAttribute('aria-hidden', 'true');
    });

    installDismiss.addEventListener('click', () => {
      installBanner.classList.remove('visible');
      installBanner.setAttribute('aria-hidden', 'true');
      sessionStorage.setItem('jap-install-dismissed', '1');
    });

    window.addEventListener('appinstalled', () => {
      installBanner.classList.remove('visible');
      installBanner.setAttribute('aria-hidden', 'true');
      deferredPrompt = null;
    });

    // --- Init ---
    renderFavorites();
  </script>
</Layout>
