---
interface Props {
  id: string;
  english: string;
  japanese: string;
  romaji: string;
  note?: string;
}

const { id, english, japanese, romaji, note } = Astro.props;
---

<article class="phrase-card" data-phrase-id={id} data-english={english.toLowerCase()} data-romaji={romaji.toLowerCase()} data-japanese={japanese}>
  <div class="phrase-card__header">
    <span class="phrase-card__english">{english}</span>
    <button class="phrase-card__fav" data-fav-id={id} aria-label={`Add ${english} to favorites`} type="button">♡</button>
  </div>
  <div class="phrase-card__japanese jp-text">{japanese}</div>
  <div class="phrase-card__romaji">{romaji}</div>
  {note && <div class="phrase-card__note">{note}</div>}
  <div class="phrase-card__actions">
    <button class="phrase-card__copy" data-copy={`${japanese}\n${romaji}`} type="button">
      <span aria-hidden="true">📋</span> Copy
    </button>
    <span class="phrase-card__show-hint" aria-hidden="true">Tap to show</span>
  </div>
</article>
